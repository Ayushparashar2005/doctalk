<?xml version="1.0" encoding="utf-8"?><!--
   Sample data extraction rules file; uncomment and customize as necessary.
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
   for details.
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude Firebase config files from cloud backup -->
        <exclude domain="sharedpref" path="com.google.firebase.auth.xml" />
        <exclude domain="sharedpref" path="com.google.firebase.firestore.xml" />
        <exclude domain="sharedpref" path="com.google.firebase.storage.xml" />
        <!-- Exclude sensitive user data -->
        <exclude domain="sharedpref" path="user_preferences.xml" />
    </cloud-backup>
    <device-transfer>
        <!-- Exclude Firebase config files from device transfer -->
        <exclude domain="sharedpref" path="com.google.firebase.auth.xml" />
        <exclude domain="sharedpref" path="com.google.firebase.firestore.xml" />
        <exclude domain="sharedpref" path="com.google.firebase.storage.xml" />
        <!-- Exclude sensitive user data -->
        <exclude domain="sharedpref" path="user_preferences.xml" />
    </device-transfer>
</data-extraction-rules>
