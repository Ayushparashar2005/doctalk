<?xml version="1.0" encoding="utf-8"?><!--
   Sample backup rules file; uncomment and customize as necessary.
   See https://developer.android.com/guide/topics/data/autobackup
   for details.
   Note: This file is ignored for devices older that API 23, even if auto backup is available.
-->
<full-backup-content>
    <!--
   <include domain="sharedpref" path="."/>
   <exclude domain="sharedpref" path="device.xml"/>
-->
    <!-- Exclude Firebase config files -->
    <exclude domain="sharedpref" path="com.google.firebase.auth.xml" />
    <exclude domain="sharedpref" path="com.google.firebase.firestore.xml" />
    <exclude domain="sharedpref" path="com.google.firebase.storage.xml" />
</full-backup-content>
