{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "doctalk-web",
	"account_id": "d43fc4fcde0d367489891df2cff4b0de",
	"compatibility_date": "2026-04-21",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"main": "./dist/_worker.js/index.js",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"kv_namespaces": [
		{
			"binding": "SESSION",
			"id": "9ed0b9af44a14be8a784df2e8e73e4ae"
		}
	]
}